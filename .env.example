# ── LLM Provider ─────────────────────────────────────────────────────────────
# Required: Set ONE of these based on your LLM_PROVIDER setting
GOOGLE_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# "google" uses Gemini 1.5 Flash | "openai" uses GPT-4o-mini
LLM_PROVIDER=google
LLM_MODEL=gemini-1.5-flash

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to local SQLite demo DB. For Postgres:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/datasupervisor
DATABASE_URL=sqlite+aiosqlite:///./demo.db

# ── Backend API Authentication ────────────────────────────────────────────────
# Generate a strong key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change_me_to_a_strong_random_key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Agent Settings ────────────────────────────────────────────────────────────
MAX_RETRIES=3
MAX_ROWS=1000
RATE_LIMIT_PER_MINUTE=30

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to disable /docs endpoint
ENV=development
